# IDs dos grupos (projetos) do Bitrix24 monitorados. Separados por vírgula.
# Padrão: 86,92,94
VITE_BITRIX_GRUPOS_ALVO=86,92,94

# URL do microsserviço de sincronização (FastAPI numa VPS própria) que mantém
# o snapshot pré-processado das tarefas. Os dados de tarefa vêm sempre daqui.
# Em dev local: http://localhost:8000
# Em prod: https://sync.seudominio.com.br
VITE_SYNC_API_URL=http://localhost:8000

# [OPCIONAL] Webhook REST de entrada do Bitrix24 (só para fallback fora do iframe).
# Formato: https://SEU_PORTAL.bitrix24.com/rest/USER_ID/TOKEN/
# ⚠️  ATENÇÃO: por ser VITE_, o token vai embutido no bundle do front.
# Use APENAS para teste/dev interno; NUNCA versione o valor real.
# Em produção dentro do Bitrix24, deixe vazio — usará window.BX24.
VITE_BITRIX_API_URL=

# [OPCIONAL] Chave da API de LLM para o assistente de IA.
# Deixe vazio se o assistente não está habilitado.
VITE_LLM_API_KEY=
