VITE_BITRIX_GRUPOS_ALVO=86,92,94,782,784

# Webhook REST de entrada do Bitrix24 (fallback fora do iframe do Bitrix, usado
# apenas para chamadas leves: identificação de usuário, grupos, departamentos).
# Formato: https://SEU_PORTAL.bitrix24.com/rest/USER_ID/TOKEN/
# ATENÇÃO: por ser VITE_, o token vai embutido no bundle do front e fica visível
# a quem abrir o app. Use só para teste/dev interno; não versione o valor real.
VITE_BITRIX_API_URL=

# URL do microsserviço de sincronização (sync-service/, FastAPI numa VPS
# própria) que mantém o snapshot pré-processado das tarefas. Sem token
# embutido — os dados de tarefa (o que antes era buscado ao vivo do Bitrix,
# inviável dado o volume) vêm sempre daqui. Ex.: https://sync.seudominio.com.br
VITE_SYNC_API_URL=
